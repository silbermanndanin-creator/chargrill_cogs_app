# Copy this file to secrets.toml and fill in your values. Do NOT commit secrets.toml.

ANTHROPIC_API_KEY = "sk-ant-..."

# Optional — Supabase persistent storage (for deployment). If both are set, the app
# stores invoices/revenue in Supabase instead of local CSV. Leave blank for local CSV.
# Use the service_role key (Project Settings -> API). Streamlit runs server-side, so
# it is not exposed to the browser — keep this file private.
SUPABASE_URL = ""
SUPABASE_KEY = ""

# Optional — only needed when you wire up Lightspeed Restaurant (K-Series).
# Leave blank to use manual revenue entry.
LIGHTSPEED_TOKEN = ""
LIGHTSPEED_BUSINESS_ID = ""

# Copy this file to secrets.toml and fill in your values. Do NOT commit secrets.toml.

ANTHROPIC_API_KEY = "sk-ant-..."

# Optional — Supabase persistent storage (for deployment). If both are set, the app
# stores invoices/revenue in Supabase instead of local CSV. Leave blank for local CSV.
# Use the service_role key (Project Settings -> API). Streamlit runs server-side, so
# it is not exposed to the browser — keep this file private.
SUPABASE_URL = ""
SUPABASE_KEY = ""

# Optional — only needed when you wire up Lightspeed Restaurant (K-Series).
# Leave blank to use manual / POS revenue entry.
LIGHTSPEED_TOKEN = ""
LIGHTSPEED_BUSINESS_ID = ""
# Optional overrides — only if your K-Series portal's base URL / path differ from the
# defaults, or the sales total sits under a non-standard field. No code change needed.
# LIGHTSPEED_BASE = "https://api.lsk.lightspeed.app"
# LIGHTSPEED_REVENUE_PATH = "/resto/financial/v1/{business_id}/sales"
# LIGHTSPEED_TOTAL_FIELD = "total_sales"

# Optional — daily email digest (sent by .github/workflows/digest.yml, not the app).
# Put these in your GitHub repo secrets rather than here. SMTP_PORT defaults to 587.
# SMTP_HOST = "smtp.gmail.com"
# SMTP_USER = "you@example.com"
# SMTP_PASS = "app-password"
# DIGEST_FROM = "you@example.com"
# DIGEST_TO = "owner@example.com, chef@example.com"
